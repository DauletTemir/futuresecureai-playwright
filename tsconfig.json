{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@data/*": ["./data/*"],
      "@fixtures/*": ["./fixtures/*"],
      "@pages/*": ["./pages/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "data/**/*.ts",
    "fixtures/**/*.ts",
    "pages/**/*.ts",
    "playwright.config.ts",
    "tests/**/*.ts"
  ]
}
