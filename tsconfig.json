{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@data/*": ["data/*"],
      "@fixtures/*": ["fixtures/*"],
      "@pages/*": ["pages/*"]
    },
    "types": ["node", "@playwright/test"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "data/**/*.ts",
    "fixtures/**/*.ts",
    "pages/**/*.ts",
    "playwright.config.ts",
    "tests/**/*.ts"
  ]
}
